        <dct:provenance>
          <dct:ProvenanceStatement rdf:nodeID="N1873dd1feb6c445eb9769931602743eb">
            <dct:description xml:lang="es">Datos recopilados por la Dirección General de Tráfico a partir del registro de accidentes con víctimas por los agentes con competencia en materia de tráfico y seguridad vial y ottras fuentes como el IMLCF y el INE.</dct:description>
